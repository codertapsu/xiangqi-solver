app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# On-device engine: the Pikafish binary (GPLv3) SHIPS in release —
# android/app/src/main/jniLibs/<abi>/libpikafish.so is tracked on purpose (the
# app is GPLv3; see docs/ON_DEVICE_ENGINE.md + LICENSE-engine). The NNUE net is
# NOT bundled — it's downloaded at runtime (the 50 MB net stays out of git/APK).
assets/engine/*.nnue
*.nnue
