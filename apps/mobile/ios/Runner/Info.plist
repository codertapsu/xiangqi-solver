	<!-- Launcher name: FIXED to the Vietnamese brand "Quân Sư Cờ Tướng" for ALL
	     system languages (per decision — the iOS app always presents the Vietnamese
	     brand). Both en.lproj and vi.lproj InfoPlist.strings set the same value so an
	     English-language device shows it too. iOS cannot rename the app at runtime.
	     (Only the permission usage strings below stay localized.) See docs/IOS_PORT.md. -->
	<key>CFBundleDisplayName</key>
	<string>Quân Sư Cờ Tướng</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<!-- Languages the app reports to Flutter. Without vi here, a Vietnamese
	     device reports `en` and the in-app locale resolver wrongly defaults to
	     English. -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>vi</string>
	</array>
	<key>CFBundleName</key>
	<string>xiangqi_solver</string>
