<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Shared container the Share Extension writes the screenshot into and the
	     app reads it from. receive_sharing_intent defaults to "group.<bundle id>". -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.codertapsu.xiangqiSolver</string>
	</array>
</dict>
</plist>
