<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for the backend (Cloud mode) + direct OpenAI (On-device
         mode). REQUIRED here in the main manifest: Flutter only adds INTERNET to
         the debug/profile manifests, so RELEASE builds (flutter build apk) have
         no network at all without this — the cause of "works in `flutter run`,
         can't connect after install". -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Floating overlay widget (visible, clearly labeled). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Foreground services for screen capture + overlay. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Persistent notification on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keep capture pipeline alive while solving. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Google Play in-app billing (hint packs). -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Network policy lives in res/xml/network_security_config.xml: HTTPS-only
         EXCEPT the plain-HTTP backend host (the backend has no TLS yet). Debug
         builds override that file to allow any LAN/emulator host. Once the
         backend is HTTPS, drop the cleartext exception and point BACKEND_URL at
         the https:// origin. See docs/PUBLISHING.md. -->
    <application
        android:label="Xiangqi Solver"
        android:name="${applicationName}"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">

        <!-- Google AdMob app id (real, codertapsu publisher pub-6124263664453069).
             The app crashes on launch if this meta-data is missing. The ad *unit*
             ids live in features/monetization/data/ad_helper.dart (kUsingRealAds);
             which formats actually SHOW is gated at runtime by the remote-config
             flags from GET /api/config (banner / appOpen / rewarded). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-6124263664453069~3920691029" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Transparent activity that launches the OFFICIAL MediaProjection
             consent dialog. The user must explicitly grant capture. -->
        <activity
            android:name=".MediaProjectionPermissionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Solver.Translucent" />

        <!-- Foreground service that owns the MediaProjection + capture pipeline. -->
        <service
            android:name=".ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Foreground service that hosts the visible floating overlay widget. -->
        <service
            android:name=".OverlayService"
            android:exported="false" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
