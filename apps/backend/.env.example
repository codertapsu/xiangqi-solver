# ---------------------------------------------------------------------------
# Xiangqi Solver Backend - environment example
# Copy to .env to override. EVERY value has a safe mock default so the app
# runs with ZERO configuration (AI_PROVIDER=mock, ENGINE_PROVIDER=mock).
# Do NOT commit a real .env (it is git-ignored).
# ---------------------------------------------------------------------------

# HTTP server
PORT=3000

# Provider selection. `mock` keeps everything offline & deterministic for dev.
# For a real deployment use OpenAI (the recommended default) — see below.
AI_PROVIDER=mock
ENGINE_PROVIDER=mock

# AI vision (cloud board-reading). OpenAI and Gemini are BOTH fully supported and
# produce the SAME result (same prompt + same parser → identical board JSON), so
# switching is a one-value change here:
#   • OpenAI (recommended default):  AI_PROVIDER=openai  + OPENAI_API_KEY  (model gpt-5.4)
#   • Gemini 3 Flash (cheaper/faster): AI_PROVIDER=gemini + GEMINI_API_KEY  (model gemini-3-flash-preview)
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
GEMINI_MODEL=gemini-3-flash-preview

# Engine (only needed when ENGINE_PROVIDER=pikafish)
# Point at the Pikafish build for YOUR OS/arch and `chmod +x` it:
#   macOS Apple Silicon -> MacOS/pikafish-apple-silicon
#   Linux x86-64        -> Linux/pikafish-<isa>   (avx2 is the safe default)
#   Windows             -> Windows\pikafish-<isa>.exe
# On macOS also clear the download quarantine: xattr -d com.apple.quarantine <file>
PIKAFISH_BINARY_PATH=
# Absolute path to pikafish.nnue (ships at the Pikafish package root).
# If left empty, Pikafish looks for "pikafish.nnue" next to the binary.
PIKAFISH_NNUE_PATH=
# UCI variant. Leave EMPTY for Pikafish. For a COMMERCIAL deployment, point
# PIKAFISH_BINARY_PATH at Fairy-Stockfish + PIKAFISH_NNUE_PATH at the CC0 xiangqi
# net, and set this to 'xiangqi' (the variant is selected before the net loads).
ENGINE_UCI_VARIANT=
ENGINE_DEFAULT_DEPTH=12
ENGINE_DEFAULT_MOVE_TIME_MS=1000
# Pikafish UCI options (ignored by the mock engine). NOTE: Pikafish has NO
# "Skill Level"/"UCI_Elo" — to make it play faster (not weaker) lower the depth
# or move time above. Threads/Hash tune speed & quality; MultiPV returns the
# top-N ranked candidate moves.
ENGINE_THREADS=1
ENGINE_HASH_MB=128
ENGINE_MULTIPV=1
ENGINE_MOVE_OVERHEAD_MS=10

# Upload limits
MAX_UPLOAD_BYTES=8388608

# Rate limiting
# Global per-IP throttle (all endpoints): RATE_LIMIT_LIMIT requests / RATE_LIMIT_TTL s.
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=30
# Per-device cap for the (paid) analysis endpoints, keyed by the x-device-id
# header. Hints are a device-local counter on the client, so this is the cheap
# server-side abuse cap that bounds OpenAI cost per device. Default: 100 / day.
RATE_LIMIT_DEVICE_WINDOW_SECONDS=86400
RATE_LIMIT_DEVICE_LIMIT=1000

# Install grants (POST /api/hints/claim). Directory for the two JSON files that
# decide a device's STARTING hint balance on (re)install (gitignored; put on a
# persistent volume in prod):
#   installs.json  — auto-managed ledger of devices already granted the free hints
#                    (so reinstalling does NOT re-grant them).
#   grants.json    — manual "Hint Grants" allowlist you edit by hand to comp a
#                    device a custom balance on every (re)install (higher priority
#                    than the ledger; re-read live, no restart needed). Format:
#                      { "<deviceId>": 1000 }
#                    Get the deviceId from the app's Settings → "Device ID".
HINTS_DATA_DIR=./data

# Remote config / feature flags — served by GET /api/config so the app is tunable
# without a new release. Change here + restart; the app picks them up on launch.
FEATURE_REWARDED_ADS=false        # rewarded ads = capped loss-leader → default off
FEATURE_BANNER_ADS=true           # banners = primary ad format
FEATURE_APP_OPEN_ADS=false
FEATURE_USE_REAL_ADS=false        # use REAL ad units (vs Google test units) → default off
HINTS_FREE_ON_INSTALL=10
HINTS_OWN_KEY_DIVISOR=3            # with the user's OWN OpenAI key: 1 hint per N analyses
ONDEVICE_ENABLED=true
ONDEVICE_NET_URL=https://github.com/official-pikafish/Networks/releases/download/master-net/pikafish.nnue
ONDEVICE_NET_BYTES=50760458       # expected size of the net (app verifies the download)
# Default OpenAI model for the app's on-device (BYO-key) board reading. On-device
# vision is OpenAI-only; users may override it in Settings. Use a capable model.
ONDEVICE_VISION_MODEL=gpt-5.4

# Visibility of OPTIONAL settings sections — all HIDDEN by default. Flip to true
# to reveal these power-user / debug sections in the app without a new release.
FEATURE_UI_BACKEND=false          # the "Backend" URL / connection-test card
FEATURE_UI_PROVIDERS=false        # the AI/engine "Providers" dropdowns
FEATURE_UI_ENGINE_TUNING=false    # the "Engine tuning" sliders (depth/threads/…)
FEATURE_UI_VISION_MODEL=false     # the on-device "Vision model" field
FEATURE_UI_LICENSES=false         # the "Open-source licenses" entry (GPLv3 notice)
